# ═══════════════════════════════════════════════════════════════════
# Design Taste Lab — Environment Configuration
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your API keys:
#   cp .env.example .env.local
#
# Or run the setup script:
#   npm run setup
# ═══════════════════════════════════════════════════════════════════


# ─── REQUIRED ────────────────────────────────────────────────────
# You need at least an Anthropic API key to use the core features.

# Anthropic API Key (powers taste analysis, questionnaires, probes, and compilation)
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI API Key (used for probe image generation when visual signals are detected)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=


# ─── OPTIONAL: DEMO MODE ────────────────────────────────────────
# Set to "true" to run with sample data — no API keys needed.
# Perfect for trying the app or developing locally.
# DEMO_MODE=true


# ─── OPTIONAL: PINTEREST INGESTION ──────────────────────────────
# Enables importing pin images from Pinterest boards.
# Uses Apify's Pinterest scraper actor.
# Get a token at: https://console.apify.com/account#/integrations
# APIFY_API_TOKEN=


# ─── OPTIONAL: UNSPLASH IMAGE SEARCH ────────────────────────────
# Enables sourcing editorial images for probe visuals.
# Only used when taste signals suggest imagery-driven design.
# Register at: https://unsplash.com/developers
# UNSPLASH_ACCESS_KEY=
# UNSPLASH_SECRET_KEY=


# ─── OPTIONAL: SEPARATE IMAGE GENERATION KEY ────────────────────
# If you want to use a different OpenAI key for GPT Image generation.
# Falls back to OPENAI_API_KEY if not set.
# OPENAI_IMAGE_API_KEY=


# ─── OPTIONAL: PROVIDER OVERRIDES ───────────────────────────────
# Swap vision provider to Gemini (for reference image analysis).
# AI_VISION_PROVIDER=gemini
# GOOGLE_API_KEY=

# Override default model versions.
# CLAUDE_MODEL=claude-sonnet-4-20250514
